generator client {
  provider = "prisma-client"
  output   = "../src/lib/prisma/generated/"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(USER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  purchases    Purchase[]
}

model Vehicle {
  id           String          @id @default(cuid())
  make         String
  model        String
  category     VehicleCategory
  year         Int
  fuelType     FuelType
  color        String
  transmission Transmission
  price        Decimal
  quantity     Int
  description  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  purchases    Purchase[]
  images       VehicleImage[]

  @@index([make])
  @@index([model])
  @@index([category])
  @@index([price])
}

model VehicleImage {
  id           String   @id @default(cuid())
  imageUrl     String
  isPrimary    Boolean  @default(false)
  displayOrder Int      @default(0)
  vehicleId    String
  createdAt    DateTime @default(now())
  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model Purchase {
  id            String   @id @default(cuid())
  userId        String
  vehicleId     String
  quantity      Int
  purchasePrice Decimal
  purchasedAt   DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id])
}

enum UserRole {
  ADMIN
  USER
}

enum VehicleCategory {
  SEDAN
  SUV
  HATCHBACK
  COUPE
  CONVERTIBLE
  WAGON
  PICKUP
  VAN
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
  CNG
}

enum Transmission {
  MANUAL
  AUTOMATIC
}
